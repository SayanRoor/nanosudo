# Runtime Environment
# Copy this file to `.env.local` for local development.
# Never commit secrets: `.env.local` and other real env files stay ignored.

# -------------------------------------------------------
# Core
# -------------------------------------------------------
NODE_ENV=development

# Domain
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# -------------------------------------------------------
# Supabase (required for storing brief submissions)
# Get these from: Supabase Dashboard → Project Settings → API
# -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"


# -------------------------------------------------------
# Brevo (newsletter / mailing list)
# API key: Brevo Dashboard → SMTP & API → API Keys
# List ID: Brevo Dashboard → Contacts → Lists → select list → ID in URL
# -------------------------------------------------------
BREVO_API_KEY="your-brevo-api-key-here"
BREVO_NEWSLETTER_LIST_ID="7"
# Sender must be verified in Brevo → Senders & IP → Domains
BREVO_SENDER_EMAIL="noreply@nanosudo.com"
BREVO_SENDER_NAME="Sayan · Nanosudo"

# -------------------------------------------------------
# Optional / future integrations
# Uncomment and fill when features require them.
# -------------------------------------------------------
# NEXT_PUBLIC_TELEGRAM_BOT_URL=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STAGING_FLAG=true
